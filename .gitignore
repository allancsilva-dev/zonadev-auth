# Variáveis de ambiente — nunca commitar
# **/ garante cobertura em qualquer subpasta (backend/, frontend/, etc.)
**/.env
**/.env.local
**/.env.production
**/.env.*.local

# Arquivos de documentação (.env.example) devem ser commitados
!**/.env.example

# Chaves RSA — nunca commitar
backend/keys/private.pem
backend/keys/public.pem
keys/
*.pem

# Dependências
**/node_modules/

# Build
**/.next/
**/dist/
**/build/

# Logs
**/*.log

# Backups gerados pelo script — armazenados localmente no VPS
backups/

# Certificados TLS gerados pelo Certbot no host
nginx/certs/

# OS
.DS_Store
Thumbs.db
