# URL do backend NestJS
# Desenvolvimento: http://localhost:3000
# Produção: https://auth.zonadev.tech
NEXT_PUBLIC_API_URL=http://localhost:3000

# Validação de claims JWT (server-side — sem NEXT_PUBLIC_)
# Usado no middleware (Edge Runtime) e em app/admin/layout.tsx (Server Component)
# NUNCA usar em Client Components — nunca chegam ao bundle do cliente
JWT_EXPECTED_ISS=auth.zonadev.tech
JWT_EXPECTED_AUD=zonadev-admin
