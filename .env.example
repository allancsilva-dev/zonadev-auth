# ─── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Banco de Dados (PostgreSQL) ──────────────────────────────────────────────
# Construída automaticamente pelo docker-compose a partir das vars abaixo
DB_HOST=postgres
DB_PORT=5432
DB_USER=zonadev_user
DB_PASSWORD=TROQUE_ESTA_SENHA
DB_NAME=zonadev_auth
# DATABASE_URL é montada pelo docker-compose — não precisa definir manualmente:
# postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── JWT RS256 ────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
# Expiração do access token em segundos (padrão: 15 minutos)
JWT_ACCESS_EXPIRES=900
# Expiração da sessão SSO (zonadev_sid) em segundos (padrão: 7 dias)
SESSION_EXPIRES=604800
# kid (Key ID) incluso no header do JWT — identifica a chave em rotação
JWT_KID=zonadev-v1

# ─── Apps e CORS dinâmicos ───────────────────────────────────────────────────
# Audiences e origins permitidas são carregadas da tabela apps.
# Registre novas apps via endpoint admin e recarregue o cache.

# ─── E-mail (SMTP) ───────────────────────────────────────────────────────────
MAIL_HOST=smtp.seudominio.com
MAIL_PORT=587
MAIL_USER=noreply@seudominio.com
MAIL_PASS=SENHA_SMTP_AQUI
MAIL_FROM="ZonaDev Auth <noreply@seudominio.com>"

# ─── Seed (dados iniciais) ────────────────────────────────────────────────────
# Senha do SUPERADMIN criado pelo seed
SEED_ADMIN_PASSWORD=SENHA_FORTE_AQUI

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
# URL pública do backend — embutida no bundle do cliente em tempo de build
NEXT_PUBLIC_API_URL=https://auth.seudominio.com

# Secrets do Next.js (server-side apenas)
NEXTAUTH_SECRET=GERE_COM_openssl_rand_-base64_32

# Validação do JWT no middleware do Next.js (sem NEXT_PUBLIC_ — nunca vai ao bundle)
JWT_EXPECTED_ISS=https://auth.seudominio.com
JWT_EXPECTED_AUD=auth.zonadev.tech

# ─── Alertas de Disco ────────────────────────────────────────────────────────
# Webhook para alertas quando disco >= 85% (Slack, Discord ou HTTP)
# Deixar vazio para desabilitar (alerta será logado localmente)
ALERT_WEBHOOK_URL=
